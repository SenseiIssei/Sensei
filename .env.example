# Sensei Configuration
# Copy this file to .env and adjust values
# Full docs: https://github.com/SenseiIssei/Sensei

# ── Model Provider ──────────────────────────────────────────
# auto = detect Ollama → local GPU → API (in that order)
SENSEI_MODEL_PROVIDER=auto

# Which API provider to use: openrouter, zai, huggingface, custom
SENSEI_API_PROVIDER=openrouter

# ── Ollama (local, free, no API key) ────────────────────────
# Install Ollama: https://ollama.com
# Pull model: ollama pull glm-5.2
SENSEI_OLLAMA_HOST=http://localhost:11434
SENSEI_OLLAMA_MODEL=glm-5.2

# ── Local model (llama.cpp / vLLM) ──────────────────────────
SENSEI_LOCAL_MODEL_PATH=
SENSEI_LOCAL_BACKEND=ollama
SENSEI_LOCAL_GPU_LAYERS=0
SENSEI_LOCAL_CONTEXT_SIZE=32768
SENSEI_LOCAL_PORT=8080

# ── OpenRouter API (recommended — free tier, many models) ──
# Get key: https://openrouter.ai/keys
SENSEI_OPENROUTER_API_KEY=
SENSEI_OPENROUTER_API_MODEL=zhipuai/glm-5.2

# ── Z.ai API (original GLM provider) ────────────────────────
# Get key: https://open.bigmodel.cn
SENSEI_ZAI_API_KEY=
SENSEI_ZAI_API_MODEL=glm-5.2

# ── HuggingFace API ─────────────────────────────────────────
# Get key: https://huggingface.co/settings/tokens
SENSEI_HUGGINGFACE_API_KEY=
SENSEI_HUGGINGFACE_API_MODEL=THUDM/glm-5.2-744b

# ── Compression Pipeline ────────────────────────────────────
SENSEI_COMPRESSION_ENABLED=true
SENSEI_CCR_TTL_HOURS=24
SENSEI_CCR_CACHE_DIR=.sensei_cache
SENSEI_OUTPUT_SHAPER=false

# ── Memory ──────────────────────────────────────────────────
SENSEI_MEMORY_ENABLED=true
SENSEI_MEMORY_DIR=.sensei_memory

# ── Server ──────────────────────────────────────────────────
SENSEI_HOST=0.0.0.0
SENSEI_PORT=7000
SENSEI_CORS_ORIGINS=http://localhost:5173,http://localhost:7000

# ── Security ────────────────────────────────────────────────
SENSEI_AUTH_ENABLED=false
SENSEI_AUTH_TOKEN=
SENSEI_RATE_LIMIT_ENABLED=true
SENSEI_RATE_LIMIT_REQUESTS=60
SENSEI_RATE_LIMIT_WINDOW_SECONDS=60
SENSEI_MAX_MESSAGE_LENGTH=32768
SENSEI_DATA_ENCRYPTION_ENABLED=true

# ── Sessions ────────────────────────────────────────────────
SENSEI_SESSION_TIMEOUT_MINUTES=60
SENSEI_SESSION_DIR=.sensei_sessions
