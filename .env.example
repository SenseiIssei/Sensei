# Sensei Configuration
# Copy this file to .env and adjust values
# Full docs: https://github.com/SenseiIssei/Sensei

# ── Model Provider ──────────────────────────────────────────
# auto = detect Ollama → local GPU → API (in that order)
SENSEI_MODEL_PROVIDER=auto

# Which API provider to use: openrouter, zai, huggingface, custom
SENSEI_API_PROVIDER=openrouter

# ── Ollama (local, free, no API key) ────────────────────────
# Install Ollama: https://ollama.com
# Pull model: ollama pull glm-5.2
SENSEI_OLLAMA_HOST=http://localhost:11434
SENSEI_OLLAMA_MODEL=glm-5.2

# ── Local model (llama.cpp / vLLM) ──────────────────────────
SENSEI_LOCAL_MODEL_PATH=
SENSEI_LOCAL_BACKEND=ollama
SENSEI_LOCAL_GPU_LAYERS=0
SENSEI_LOCAL_CONTEXT_SIZE=32768
SENSEI_LOCAL_PORT=8080

# ── OpenRouter API (recommended — free tier, many models) ──
# Get key: https://openrouter.ai/keys
SENSEI_OPENROUTER_API_KEY=
SENSEI_OPENROUTER_API_MODEL=zhipuai/glm-5.2

# ── Z.ai API (original GLM provider) ────────────────────────
# Get key: https://open.bigmodel.cn
SENSEI_ZAI_API_KEY=
SENSEI_ZAI_API_MODEL=glm-5.2

# ── HuggingFace API ─────────────────────────────────────────
# Get key: https://huggingface.co/settings/tokens
SENSEI_HUGGINGFACE_API_KEY=
SENSEI_HUGGINGFACE_API_MODEL=THUDM/glm-5.2-744b

# ── OpenAI API (GPT-4o, o1, o3, etc.) ──────────────────────
# Get key: https://platform.openai.com/api-keys
SENSEI_OPENAI_API_KEY=
SENSEI_OPENAI_API_MODEL=gpt-4o

# ── Anthropic / Claude API (Claude 3.5 Sonnet, Opus, Haiku) ─
# Get key: https://console.anthropic.com/settings/keys
SENSEI_ANTHROPIC_API_KEY=
SENSEI_ANTHROPIC_API_MODEL=claude-3-5-sonnet-20241022

# ── Google Gemini API (Gemini 2.0 Flash, Pro) ──────────────
# Get key: https://aistudio.google.com/apikey
SENSEI_GOOGLE_API_KEY=
SENSEI_GOOGLE_API_MODEL=gemini-2.0-flash

# ── Groq API (ultra-fast, free tier, Llama 3.3) ────────────
# Get key: https://console.groq.com/keys
SENSEI_GROQ_API_KEY=
SENSEI_GROQ_API_MODEL=llama-3.3-70b-versatile

# ── Mistral API (Mistral Large, Codestral) ─────────────────
# Get key: https://console.mistral.ai/api-keys
SENSEI_MISTRAL_API_KEY=
SENSEI_MISTRAL_API_MODEL=mistral-large-latest

# ── Together AI API (Llama, Qwen, DeepSeek) ────────────────
# Get key: https://api.together.xyz/settings/api-keys
SENSEI_TOGETHER_API_KEY=
SENSEI_TOGETHER_API_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── DeepSeek API (DeepSeek V3, R1) ─────────────────────────
# Get key: https://platform.deepseek.com/api_keys
SENSEI_DEEPSEEK_API_KEY=
SENSEI_DEEPSEEK_API_MODEL=deepseek-chat

# ── Cohere API (Command R+) ────────────────────────────────
# Get key: https://dashboard.cohere.com/api-keys
SENSEI_COHERE_API_KEY=
SENSEI_COHERE_API_MODEL=command-r-plus

# ── Fireworks AI API (Llama, Qwen) ─────────────────────────
# Get key: https://fireworks.ai/apikeys
SENSEI_FIREWORKS_API_KEY=
SENSEI_FIREWORKS_API_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# ── Perplexity API (Sonar, Online models) ──────────────────
# Get key: https://www.perplexity.ai/settings/api
SENSEI_PERPLEXITY_API_KEY=
SENSEI_PERPLEXITY_API_MODEL=sonar-pro

# ── Compression Pipeline ────────────────────────────────────
SENSEI_COMPRESSION_ENABLED=true
SENSEI_CCR_TTL_HOURS=24
SENSEI_CCR_CACHE_DIR=.sensei_cache
SENSEI_OUTPUT_SHAPER=false

# ── Memory ──────────────────────────────────────────────────
SENSEI_MEMORY_ENABLED=true
SENSEI_MEMORY_DIR=.sensei_memory

# ── Server ──────────────────────────────────────────────────
SENSEI_HOST=0.0.0.0
SENSEI_PORT=7000
SENSEI_CORS_ORIGINS=http://localhost:5173,http://localhost:7000

# ── Security ────────────────────────────────────────────────
SENSEI_AUTH_ENABLED=false
SENSEI_AUTH_TOKEN=
SENSEI_RATE_LIMIT_ENABLED=true
SENSEI_RATE_LIMIT_REQUESTS=60
SENSEI_RATE_LIMIT_WINDOW_SECONDS=60
SENSEI_MAX_MESSAGE_LENGTH=32768
SENSEI_DATA_ENCRYPTION_ENABLED=true

# ── Sessions ────────────────────────────────────────────────
SENSEI_SESSION_TIMEOUT_MINUTES=60
SENSEI_SESSION_DIR=.sensei_sessions

# ── User Authentication (Public Chat) ───────────────────────
# JWT secret for user auth tokens (auto-generated if not set)
SENSEI_JWT_SECRET=
# Token expiry in hours (default: 168 = 7 days)
SENSEI_JWT_EXPIRY_HOURS=168
# User data file (JSON-based, swap for database in production)
SENSEI_USERS_FILE=.sensei_users.json
